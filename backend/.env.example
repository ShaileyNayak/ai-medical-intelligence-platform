# SQLite (local default)
DATABASE_URL=sqlite:///./predictions.db

# PostgreSQL (Docker / production) — uncomment and set password:
# DATABASE_URL=postgresql://medai_user:medai_pass@localhost:5432/medai

# Per-module weights (one .pth under model_weights/<scan_type>/)
CHEST_XRAY_MODEL_PATH=./model_weights/chest_xray/best_model.pth
BRAIN_MRI_MODEL_PATH=./model_weights/brain_mri/best_model.pth
SKIN_LESION_MODEL_PATH=./model_weights/skin_lesion/best_model.pth
MODEL_PATH=./model_weights/chest_xray/best_model.pth
MODEL_VERSION=resnet18-v1.0
UPLOAD_DIR=./static/uploads
HEATMAP_DIR=./static/heatmaps
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8501
LOG_LEVEL=INFO
