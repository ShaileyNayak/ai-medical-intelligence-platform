# Copy to .env and fill secrets. Never commit .env.

# Database (docker-compose overrides DATABASE_URL for backend service)
DB_PASSWORD=medai_pass
DATABASE_URL=sqlite:///./medical_ai.db

# Model
MODEL_PATH=../model/checkpoints/best_model.pt
MODEL_VERSION=resnet18-v1.0
UPLOAD_DIR=./static/uploads
HEATMAP_DIR=./static/heatmaps

# LLM (leave empty to use template reports)
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8501
LOG_LEVEL=INFO

# Frontend
VITE_API_BASE_URL=
