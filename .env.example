# Render / production notes
# DATABASE_URL is injected by Render from the managed Postgres instance
# (postgres:// is auto-normalized to postgresql:// in app settings).
#
# LLM_API_KEY  — set in Render dashboard (secret)
# MODEL_URL    — optional HTTPS URL to best_model.pth if not baked into the image
# CORS_ORIGINS — https://<medai-frontend>.onrender.com
# VITE_API_BASE_URL — https://<medai-backend>.onrender.com (frontend build)

# --- Postgres (Docker Compose local) ---
POSTGRES_DB=medai
POSTGRES_USER=medai_user
POSTGRES_PASSWORD=medai_pass
POSTGRES_PORT=5432

# --- Host ports (Compose) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Backend ---
DATABASE_URL=sqlite:///./predictions.db
MODEL_PATH=/app/model_weights/best_model.pth
MODEL_VERSION=resnet18-v1.0
UPLOAD_DIR=/app/static/uploads
HEATMAP_DIR=/app/static/heatmaps
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
MODEL_URL=

# --- Frontend build ---
VITE_API_BASE_URL=
